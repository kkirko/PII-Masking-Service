# PII Masking Service Configuration
# Copy this file to .env and adjust values as needed

# ============================================================
# ENCRYPTION KEY (REQUIRED for production)
# ============================================================
# AES-256-SIV key (64 bytes, base64 encoded)
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(64)).decode())"
# If not set, the service will generate a demo key and persist it to `.demo_pii_key.b64`
# so the demo remains decryptable across restarts. For real deployments, always set PII_KEY_B64.
# PII_KEY_B64=your_base64_encoded_64_byte_key_here

# ============================================================
# MASKING CONFIGURATION
# ============================================================
# Mask version for traceability
MASK_VERSION=v1

# Enable/disable unmask endpoint (set to false in production!)
ENABLE_UNMASK=true
# Enable/disable text unmask endpoint (defaults to ENABLE_UNMASK)
ENABLE_UNMASK_TEXT=true

# ============================================================
# SCALE FACTORS (Diagonal Matrix)
# ============================================================
# Numeric field multipliers (must be > 0)
SCALE_AMOUNT=1.37
SCALE_AVAILABLE_BALANCE=0.83
SCALE_CREDIT_LIMIT=1.11

# ============================================================
# CATEGORICAL MAPPING
# ============================================================
# Seed for MCC permutation (if not set, derived from PII_KEY_B64)
# CAT_SEED=12345678901234567890

# ============================================================
# LOGGING
# ============================================================
# Optional salt for safe log hashing
# LOG_HASH_SALT=change-me

# ============================================================
# MICROSOFT PRESIDIO
# ============================================================
# Score threshold for text PII detection.
PRESIDIO_SCORE_THRESHOLD=0.35

# Default English spaCy model used by Microsoft Presidio.
# Install with: python -m spacy download en_core_web_lg
PRESIDIO_SPACY_MODEL=en_core_web_lg

# Demo-only: include raw source text previews in Presidio responses and /v1/demo/run artifacts.
# Set to false outside controlled demos to suppress `original_text`, `scanned_text`, and `text_preview`.
PRESIDIO_DEMO_INCLUDE_ORIGINAL=true

# Future RU/local-language support:
# add custom recognizers and configure a dedicated NLP engine/model for the target language.
